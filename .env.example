# Copy this to .env and fill in values. Never commit .env to git.

# Discord webhook URL for the relational-memory / CC communication channel.
# Create a webhook in Discord: Server Settings → Integrations → Webhooks → New Webhook
# Paste the webhook URL here.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
